{
	"name": "no-red-disk",
	"version": "1.1.0",
	"description": "我的磁盘怎么红红的，是要谈恋爱了吗",
	"main": "electron/main.js",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"electron:dev": "concurrently \"cross-env BROWSER=none vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
		"electron:build": "npm run build && electron-builder",
		"preview": "vite preview",
		"verify:rules": "node scripts/verify-rules.js"
	},
	"build": {
		"appId": "com.cdrive.cleaner",
		"productName": "我的磁盘怎么红红的，是要谈恋爱了吗",
		"electronDist": "node_modules/electron/dist",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"electron/**/*",
			"package.json"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "public/icon.png"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": "always",
			"shortcutName": "我的磁盘怎么红红的，是要谈恋爱了吗"
		}
	},
	"keywords": [
		"cleaner",
		"disk-cleanup",
		"c-drive",
		"windows"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@ant-design/icons": "^6.3.2",
		"antd": "^6.5.0",
		"echarts": "^6.1.0",
		"echarts-for-react": "^3.0.6",
		"gsap": "^3.15.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"three": "^0.185.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.185.0",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0",
		"electron": "^42.5.1",
		"electron-builder": "^26.15.3",
		"jsrepo": "^3.8.0",
		"typescript": "^6.0.3",
		"vite": "^8.1.0",
		"wait-on": "^9.0.10"
	}
}
